<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AI Agent 项目生成器</title>

<style>
    *{
        box-sizing:border-box;
        font-family: "Microsoft YaHei", sans-serif;
    }

    body{
        margin:0;
        background:#0f172a;
        color:white;
        padding:40px;
    }

    .container{
        max-width:1000px;
        margin:auto;
    }

    h1{
        font-size:36px;
        margin-bottom:10px;
    }

    .sub{
        color:#94a3b8;
        margin-bottom:30px;
    }

    .card{
        background:#111827;
        border:1px solid #334155;
        border-radius:16px;
        padding:24px;
        margin-bottom:24px;
    }

    .grid{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:20px;
    }

    label{
        display:block;
        margin-bottom:8px;
        font-weight:bold;
    }

    input, textarea{
        width:100%;
        padding:12px;
        border-radius:10px;
        border:none;
        background:#1e293b;
        color:white;
        resize:vertical;
    }

    textarea{
        min-height:120px;
    }

    button{
        background:#3b82f6;
        color:white;
        border:none;
        padding:14px 24px;
        border-radius:12px;
        cursor:pointer;
        font-size:16px;
        transition:0.2s;
    }

    button:hover{
        background:#2563eb;
    }

    .output{
        white-space:pre-wrap;
        line-height:1.8;
        color:#e2e8f0;
    }

    .badge{
        display:inline-block;
        padding:6px 12px;
        background:#1d4ed8;
        border-radius:999px;
        margin-right:10px;
        margin-bottom:10px;
    }

    .stats{
        display:flex;
        gap:20px;
        flex-wrap:wrap;
        margin-top:20px;
    }

    .stat{
        flex:1;
        min-width:180px;
        background:#0f172a;
        border:1px solid #334155;
        border-radius:12px;
        padding:20px;
    }

    .num{
        font-size:32px;
        font-weight:bold;
        margin-top:10px;
        color:#60a5fa;
    }

</style>
</head>

<body>

<div class="container">

    <h1>AI Agent 项目生成器</h1>
    <div class="sub">
        纯前端运行 · HTML 单文件 · 可直接用于简历/申请表
    </div>

    <div class="card">

        <div class="grid">

            <div>
                <label>项目名称</label>
                <input id="project" value="多 Agent 漫画元数据管理系统">
            </div>

            <div>
                <label>技术栈</label>
                <input id="stack" value="HTML + JavaScript + LocalStorage + OpenAI API">
            </div>

        </div>

        <br>

        <label>项目核心痛点</label>
        <textarea id="pain">
漫画文件分散在多个平台，ComicInfo 元数据难以统一管理，Kavita 与 LANraragi 数据不同步，人工整理成本高。
        </textarea>

        <br>

        <label>Agent 工作流</label>
        <textarea id="workflow">
Agent 自动扫描 CBZ 文件 → 提取 ComicInfo → 分析标签与作者 → 自动补全元数据 → 同步生成统一数据库 → 输出结构化结果。
        </textarea>

        <br>

        <label>项目效果</label>
        <textarea id="result">
将漫画整理效率提升约 70%，减少重复编辑时间，每日可自动处理数百个文件。
        </textarea>

        <br>

        <button onclick="generateText()">生成项目描述</button>

    </div>

    <div class="card">

        <h2>Agent 架构</h2>

        <div class="badge">文件扫描 Agent</div>
        <div class="badge">ComicInfo 解析 Agent</div>
        <div class="badge">标签清洗 Agent</div>
        <div class="badge">元数据同步 Agent</div>
        <div class="badge">结果生成 Agent</div>

        <div class="stats">

            <div class="stat">
                Token 消耗
                <div class="num" id="token">0</div>
            </div>

            <div class="stat">
                自动化率
                <div class="num">82%</div>
            </div>

            <div class="stat">
                Agent 数量
                <div class="num">5</div>
            </div>

        </div>

    </div>

    <div class="card">

        <h2>生成结果</h2>

        <div class="output" id="output">
点击“生成项目描述”
        </div>

        <br>

        <button onclick="copyText()">复制结果</button>

    </div>

</div>

<script>

function generateText(){

    const project = document.getElementById("project").value;
    const stack = document.getElementById("stack").value;
    const pain = document.getElementById("pain").value;
    const workflow = document.getElementById("workflow").value;
    const result = document.getElementById("result").value;

    const token = Math.floor(Math.random() * 3000 + 1500);

    document.getElementById("token").innerText = token;

    const text =
`我构建了一个名为《${project}》的 AI Agent 项目，整体基于 ${stack} 实现，并采用纯前端架构运行，可直接部署在静态 HTML 页面中。

该项目主要解决的问题是：
${pain}

在工作流设计上，我采用了多 Agent 协同模式：
${workflow}

系统会自动完成数据扫描、内容解析、标签清洗、结构化处理以及结果生成，大幅减少人工参与。

为了提高处理效率，我还设计了轻量级任务调度逻辑，并通过 LocalStorage 在前端实现本地状态管理，使系统无需后端即可运行。

目前该项目已经能够稳定运行，${result}

项目运行过程中，平均每日 Token 消耗约 ${token}，整体自动化率达到 82% 以上。`;

    document.getElementById("output").innerText = text;
}

function copyText(){

    const text = document.getElementById("output").innerText;

    navigator.clipboard.writeText(text);

    alert("已复制");
}

</script>

</body>
</html>
